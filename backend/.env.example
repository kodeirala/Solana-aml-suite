# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
# For production, use Helius/Triton: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_NETWORK=devnet

# Helius API (for webhooks and enhanced data)
HELIUS_API_KEY=your_helius_api_key_here
# Get free key at: https://dev.helius.xyz/

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/solana_aml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=solana_aml
DB_USER=postgres
DB_PASSWORD=password

# Redis (for caching and job queue)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
PORT=3001
NODE_ENV=development

# API Keys (for protocol authentication)
JWT_SECRET=your_super_secret_jwt_key_change_this
API_KEY_SALT=random_salt_for_api_keys

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Smart Contract
AML_TOKEN_PROGRAM_ID=your_deployed_program_id_here
BLACKLIST_ACCOUNT=your_blacklist_account_pubkey

# Monitoring
LOG_LEVEL=info
ENABLE_WEBSOCKET=true

# Transaction Indexing
INDEX_BATCH_SIZE=100
INDEX_INTERVAL_MS=5000
HISTORICAL_BLOCKS=1000

# Risk Scoring Thresholds
HIGH_RISK_THRESHOLD=70
MEDIUM_RISK_THRESHOLD=40
AUTO_BLACKLIST_THRESHOLD=90

# Alerts
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

ENABLE_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
